{
  "name": "@ckb-cto/supplier",
  "version": "0.1.1",
  "description": "CLI tool for maintaining CKB Time Oracle (CTO) cell groups.",
  "type": "module",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm build",
    "format": "prettier --write .",
    "start": "node bin/run.js",
    "dev": "tsx bin/dev.js"
  },
  "keywords": [
    "ckb",
    "nervos",
    "oracle",
    "time",
    "cli"
  ],
  "author": "Hanssen",
  "license": "MIT",
  "dependencies": {
    "@ckb-ccc/shell": "^1.1.25",
    "@ckb-cto/lib": "workspace:*",
    "@oclif/core": "^4.10.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "bin": {
    "ckb-cto": "./bin/run.js"
  },
  "oclif": {
    "bin": "ckb-cto",
    "commands": "./dist/commands",
    "dirname": "ckb-cto",
    "topicSeparator": " ",
    "additionalHelpFlags": [
      "-h",
      "help"
    ],
    "additionalVersionFlags": [
      "-v",
      "version"
    ]
  }
}
